# Lines configured by zsh-newuser-install
HISTFILE=~/.histfile
HISTSIZE=1000
SAVEHIST=1000
setopt autocd extendedglob nomatch notify
unsetopt beep
# End of lines configured by zsh-newuser-install
# The following lines were added by compinstall
zstyle :compinstall filename '/home/christophe/.zshrc'

autoload -Uz compinit
compinit
# End of lines added by compinstall
PATH=$PATH:~/go/bin

eval "$(/home/linuxbrew/.linuxbrew/bin/brew shellenv)"

export PATH="/home/christophe/.local/bin:$PATH"
alias vim=nvim
alias r=ranger
alias c=yazi

alias cm=chezmoi
alias cdcm="cd ~/.local/share/chezmoi"
export EDITOR=nvim
export VISUAL=nvim
alias lg=lazygit
alias addnew="vim ~/.local/share/chezmoi/.chezmoidata/packages.yaml"
alias cmg="lg -p ~/.local/share/chezmoi"
alias tw="taskwarrior-tui"


plugins=(git azure colorize common aliases docker kubectl z )
source $(brew --prefix)/share/zsh-autosuggestions/zsh-autosuggestions.zsh


source ~/.profile

# Allow ctrl left and right
bindkey '^[[1;5C' emacs-forward-word
bindkey '^[[1;5D' emacs-backward-word
# Ctrl backspace and delete
bindkey '^H' backward-kill-word
bindkey '^?' backward-kill-word
# Make Ctrl+Delete kill the next word
bindkey '^[[3;5~' kill-word

# NEEDS TO BE AT THE END
eval "$(starship init zsh)"


